# Companies House (FREE): register an app at
#   https://developer.company-information.service.gov.uk/
# then create a "REST" / Live API key and paste it here.
COMPANIES_HOUSE_API_KEY=

# Dashboard database (use the SERVICE ROLE key - server only).
SUPABASE_URL=https://qwblxytpznslidwjoxvt.supabase.co
SUPABASE_SERVICE_KEY=
AGENT_ID=

# Groq brain (free) - same key as the other agents.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Local fallback settings (overridden by the dashboard's agent row) ---
NAME_KEYWORDS=kitchen,kitchens,bathroom,bathrooms,bedroom,bedrooms,interiors,kbb,tiles,worktops,fitted furniture
INCORPORATED_WITHIN_DAYS=45
COMPANY_STATUS=active
MAX_PER_RUN=25
USE_BRAIN=true
MIN_SCORE=50
