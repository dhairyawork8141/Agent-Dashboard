# ============================================================
#  CAD Illustrators - Virtual Worlds job-watch agent
#  Copy to ".env" for local runs. In GitHub Actions use Secrets/Variables.
# ============================================================

# --- Job board APIs (both free) ---
# Adzuna:  https://developer.adzuna.com   -> App ID + App Key
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Reed:    https://www.reed.co.uk/developers   -> one API key
REED_API_KEY=
# Jooble:  https://jooble.org/api/about        -> free API key on request (global aggregator)
JOOBLE_API_KEY=
# Careerjet: https://www.careerjet.com/partners/  -> free affiliate id (global aggregator)
CAREERJET_AFFID=
# JSearch (PAID, RapidAPI): unlocks Google Jobs -> LinkedIn, Indeed, Glassdoor, ZipRecruiter, Monster.
# Leave blank to keep it off. https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# --- Dashboard database (optional but recommended) ---
# From Supabase -> Project Settings -> API.  Use the SERVICE ROLE key here (server only!).
# AGENT_ID is the id of the agent row (Supabase -> Table editor -> agents -> copy id).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
AGENT_ID=

# --- Claude enrichment (toggle is set in the dashboard; this is just the key) ---
ANTHROPIC_API_KEY=
ENRICH_MODEL=claude-haiku-4-5-20251001

# --- Email digest (toggle is set in the dashboard; these are the credentials) ---
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=dhairya@cadillustrator.com
SMTP_PASS=
ALERT_FROM=dhairya@cadillustrator.com
ALERT_TO=your-personal@email.com

# --- Local fallback settings (used only when Supabase is NOT connected) ---
COUNTRIES=gb,us,ca,au,nz,de,fr,nl
CAREERJET_LOCALES=en_GB,en_US
JSEARCH_COUNTRIES=gb,us
JSEARCH_MAX_PER_RUN=2
MAX_DAYS_OLD=3
ENRICH_WITH_CLAUDE=false
SEND_EMAIL=false
