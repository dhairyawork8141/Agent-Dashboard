# ============================================================
#  CAD Illustrators - VW Contact Finder (agent #2)
#  Copy to ".env" for local runs. In GitHub Actions use Secrets.
# ============================================================

# --- Apollo.io API ---
# Apollo -> Settings -> Integrations -> API  ->  create / copy your API key.
APOLLO_API_KEY=

# --- Dashboard database (same Supabase project as agent #1) ---
# Use the SERVICE ROLE key here (server only!).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# AGENT_ID is the contact-finder row seeded by agent-dashboard-schema-v2.sql:
AGENT_ID=b7e6d5c4-3a2b-4c1d-9e8f-0a1b2c3d4e5f

# --- Local fallback toggles (used only when the dashboard row has no settings) ---
MAX_PER_RUN=10
TIERS=HOT - Virtual Worlds,WARM - Winner/Cyncly
SKIP_RECRUITERS=true
REVEAL_PHONE=false
LOCATIONS=United Kingdom
